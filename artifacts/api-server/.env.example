# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/forgestudio"

# ============================================
# JWT CONFIGURATION
# ============================================
# Secret key for signing JWT tokens
# Should be a long, random string (min 32 characters)
# Generate: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-please-change-this-in-production"

# Token expiry duration
JWT_EXPIRY="7d"

# ============================================
# EMAIL SERVICE (OPTIONAL - Resend)
# ============================================
# Note: Resend is limited to 100 emails/day on free tier
# For unlimited free email, use Nodemailer with your own SMTP instead
# Get API key from: https://resend.com/
RESEND_API_KEY="re_your_resend_api_key_here"

# ============================================
# EMAIL SERVICE (ALTERNATIVE - Nodemailer/SMTP)
# ============================================
# Use this if you want unlimited free emails
# Example using Gmail: https://nodemailer.com/smtp/gmail/
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-specific-password"
# SMTP_FROM="noreply@forgestudio.com"

# ============================================
# FRONTEND URL (For email links)
# ============================================
# Used in email verification and password reset links
# Should point to your frontend application
FRONTEND_URL="http://localhost:5173"

# Production example:
# FRONTEND_URL="https://forgestudio.com"

# ============================================
# GOOGLE OAUTH (Optional - for token verification)
# ============================================
# Get from: https://console.cloud.google.com/
# Only needed if verifying Google tokens on backend
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# NODE ENVIRONMENT
# ============================================
# development | production | test
NODE_ENV="development"

# ============================================
# LOGGING
# ============================================
# none | error | warn | info | debug
LOG_LEVEL="info"

# ============================================
# PORT (Optional)
# ============================================
# Port to run the API server on
PORT="3000"

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS
# Add your frontend domain here for production
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ============================================
# RATE LIMITING
# ============================================
# Requests per window (optional - implement before production)
# RATE_LIMIT_WINDOW_MS="15m"
# RATE_LIMIT_MAX_REQUESTS="100"
