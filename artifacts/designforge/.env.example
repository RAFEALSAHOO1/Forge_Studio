# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# API CONFIGURATION
# ============================================
# Backend API base URL
# The API routes will be appended to this base URL
# Examples:
#   Development: http://localhost:3000/api
#   Production: https://api.forgestudio.com
VITE_API_URL="http://localhost:3000/api"

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Required for Google Sign-In and Sign-Up
# Get from: https://console.cloud.google.com/
# Copy the "Client ID" (ends with .apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Application name
VITE_APP_NAME="Forge Studio"

# Application title (used in document title)
VITE_APP_TITLE="Forge Studio - Design with Freedom"

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable features
# VITE_ENABLE_GOOGLE_OAUTH="true"
# VITE_ENABLE_EMAIL_AUTH="true"
# VITE_ENABLE_PHONE_OTP="false"

# ============================================
# ANALYTICS (Optional)
# ============================================
# Google Analytics ID (optional)
# VITE_GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# ============================================
# BUILD CONFIGURATION
# ============================================
# Base path for deployed application (if not at root)
# VITE_BASE_URL="/"
